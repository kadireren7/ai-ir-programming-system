# Copy to `.env` in the repo root (never commit `.env`).
# OpenAI: https://platform.openai.com/api-keys

OPENAI_API_KEY=
# Optional override:
# OPENAI_IR_MODEL=gpt-4o-mini

# Web console (`torqa-console` / `python -m webui`):
# TORQA_WEB_HOST=127.0.0.1
# TORQA_WEB_PORT=8000

# Rust bridge subprocess timeout (seconds):
# TORQA_RUST_TIMEOUT_SEC=120

# Optional third-party projection hook:
# TORQA_PROJECTION_MODULE=my_pkg.hooks:merge_artifacts
