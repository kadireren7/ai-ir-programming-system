# --------------------------------------------------
# Torqa Core
# --------------------------------------------------
TORQA_ENV=development
TORQA_LOG_LEVEL=info

# --------------------------------------------------
# Dashboard / Frontend
# --------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --------------------------------------------------
# Supabase
# --------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --------------------------------------------------
# API / scan engine
# --------------------------------------------------
TORQA_API_URL=http://localhost:8000
TORQA_API_KEY=
TORQA_API_KEY_PEPPER=

# Dashboard POST /api/scan: server-preview (default) | hosted-python | python-engine (stub)
TORQA_SCAN_PROVIDER=server-preview
# Base URL for hosted-python (POST {TORQA_ENGINE_URL}/scan with { source, content })
TORQA_ENGINE_URL=

# --------------------------------------------------
# Scheduled scans (cron tick worker)
# --------------------------------------------------
# Shared secret for POST /api/scan-schedules/cron/tick. Send header:
#   Authorization: Bearer <TORQA_CRON_SECRET>
# Vercel Cron, GitHub Actions, or scripts/torqa-cron-tick.sh should call the tick URL on a schedule.
# Leave empty in local dev if you do not run the worker.
TORQA_CRON_SECRET=

# --------------------------------------------------
# Alert email (Resend)
# --------------------------------------------------
# API key from https://resend.com — enables alert destination type "email" and validates "Test" in /alerts.
# Without this, email tests return a clear error and live scan alert fan-out skips email (non-fatal).
RESEND_API_KEY=

# From address Resend accepts for your domain (must be verified in Resend). Example:
#   Torqa Alerts <alerts@yourdomain.com>
# Falls back in code if unset (Resend onboarding domain may apply).
TORQA_ALERT_FROM_EMAIL=

# --------------------------------------------------
# GitHub repository webhooks
# --------------------------------------------------
# HMAC secret GitHub shows when you create the webhook. Used to verify X-Hub-Signature-256 on
# POST /api/webhooks/github. Must match the secret configured in the GitHub repo webhook UI.
GITHUB_WEBHOOK_SECRET=

# --------------------------------------------------
# n8n (server-side workflow list preview)
# --------------------------------------------------
# Base URL of your n8n instance, no trailing slash, e.g. https://n8n.internal.example.com
# Used only by GET /api/integrations/n8n/workflows (authenticated dashboard users).
N8N_BASE_URL=

# n8n API key (Settings → API in n8n). Stored in process env on the dashboard host, not in the browser.
# Use a read-scoped key in production.
N8N_API_KEY=

# --------------------------------------------------
# GitHub OAuth App (Integration Center)
# --------------------------------------------------
# Create at: https://github.com/settings/developers → OAuth Apps → New OAuth App
# Callback URL: http://localhost:3000/api/integrations/github/oauth/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# --------------------------------------------------
# Token Encryption (M2+)
# --------------------------------------------------
# 32-byte hex key for AES-256-GCM token storage.
# Generate with: openssl rand -hex 32
TORQA_TOKEN_ENCRYPTION_KEY=

# --------------------------------------------------
# GitHub Integration (legacy / CLI)
# --------------------------------------------------
GITHUB_TOKEN=

# --------------------------------------------------
# Optional Analytics
# --------------------------------------------------
POSTHOG_KEY=
