# --------------------------------------------------
# Torqa Core
# --------------------------------------------------
TORQA_ENV=development
TORQA_LOG_LEVEL=info

# --------------------------------------------------
# Dashboard / Frontend
# --------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --------------------------------------------------
# Supabase (future)
# --------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --------------------------------------------------
# API / Backend (future)
# --------------------------------------------------
TORQA_API_URL=http://localhost:8000
TORQA_API_KEY=
TORQA_API_KEY_PEPPER=

# Dashboard POST /api/scan: server-preview (default) | hosted-python | python-engine (stub)
TORQA_SCAN_PROVIDER=server-preview
# Base URL for hosted-python (POST {TORQA_ENGINE_URL}/scan with { source, content })
TORQA_ENGINE_URL=

# Optional: future Vercel Cron / worker auth for POST /api/scan-schedules/cron/tick (Bearer secret)
TORQA_CRON_SECRET=

# --------------------------------------------------
# GitHub Integration (future)
# --------------------------------------------------
GITHUB_TOKEN=

# --------------------------------------------------
# Optional Analytics
# --------------------------------------------------
POSTHOG_KEY=
