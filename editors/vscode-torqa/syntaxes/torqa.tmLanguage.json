{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "torqa",
  "patterns": [
    { "include": "#comment" },
    { "include": "#keyword" },
    { "include": "#identifier" }
  ],
  "repository": {
    "comment": {
      "patterns": [
        {
          "name": "comment.line.number-sign.torqa",
          "match": "#.*$"
        }
      ]
    },
    "keyword": {
      "patterns": [
        {
          "name": "keyword.control.torqa",
          "match": "\\b(?i)(module|intent|include|requires|ensures|forbid|unless|flow|when|if|goal|input|require|transition|result|emit|validate|find|verify|create|by|locked|login_success|session)\\b"
        }
      ]
    },
    "identifier": {
      "patterns": [
        {
          "name": "variable.other.torqa",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  },
  "scopeName": "source.torqa"
}
