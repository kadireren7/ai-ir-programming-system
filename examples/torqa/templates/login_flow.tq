# Auth / login with session + audit: module, forbid, ensures, result, then two flow steps.
# Each flow line = exactly two ASCII spaces + create session OR emit login_success (lowercase).
# requires must list ip_address when using emit login_success (audit arity).

module your.namespace.here

intent user_login
requires username, password, ip_address
forbid locked
ensures session.created
result Login completed

flow:
  create session
  emit login_success
